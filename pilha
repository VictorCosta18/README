#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX 100

// =====================================================
// SISTEMA DE CHAMADAS DE EMERGÊNCIA (PILHA - LIFO)
// Última ocorrência registrada será atendida primeiro
// =====================================================

// ===== Estrutura =====
typedef struct {
    int protocolo;
    char local[50];
    char tipoEmergencia[50];
    char horario[20];
} Emergencia;

typedef struct {
    Emergencia dados[MAX];
    int topo;
} Pilha;

// ===== Funções ===== 
void inicializar(Pilha *p) {
    p->topo = -1;
}

// Verifica se já existe protocolo (evita duplicidade)
int existeProtocolo(Pilha *p, int protocolo) {
    for (int i = 0; i <= p->topo; i++) {
        if (p->dados[i].protocolo == protocolo)
            return 1;
    }
    return 0;
}

// Inserir nova emergência (push)
int registrarEmergencia(Pilha *p, Emergencia e) {
    if (p->topo == MAX - 1) return 0; // pilha cheia
    if (existeProtocolo(p, e.protocolo)) return -1; // duplicado

    p->dados[++p->topo] = e;
    return 1;
}

// Atender emergência (pop)
int atenderEmergencia(Pilha *p) {
    if (p->topo == -1) return 0; // pilha vazia

    printf("\nAtendendo emergencia:\n");
    printf("%d | %s | %s | %s\n",
           p->dados[p->topo].protocolo,
           p->dados[p->topo].local,
           p->dados[p->topo].tipoEmergencia,
           p->dados[p->topo].horario);

    p->topo--;
    return 1;
}

// Listar emergências (do topo para base)
void listarEmergencias(Pilha *p) {
    if (p->topo == -1) {
        printf("Nenhuma emergencia registrada!\n");
        return;
    }

    printf("\n===== EMERGENCIAS PENDENTES =====\n");

    for (int i = p->topo; i >= 0; i--) {
        printf("%d | %s | %s | %s\n",
               p->dados[i].protocolo,
               p->dados[i].local,
               p->dados[i].tipoEmergencia,
               p->dados[i].horario);
    }
}

// Salvar em CSV
void salvar(Pilha *p) {
    FILE *f = fopen("emergencias.csv", "w");
    if (!f) return;

    fprintf(f, "protocolo;local;tipoEmergencia;horario\n");

    for (int i = 0; i <= p->topo; i++) {
        fprintf(f, "%d;%s;%s;%s\n",
                p->dados[i].protocolo,
                p->dados[i].local,
                p->dados[i].tipoEmergencia,
                p->dados[i].horario);
    }

    fclose(f);
}

// Carregar CSV
void carregar(Pilha *p) {
    FILE *f = fopen("emergencias.csv", "r");
    if (!f) return;

    char linha[150];
    fgets(linha, 150, f); // pula cabeçalho

    Emergencia e;

    while (fscanf(f, "%d;%49[^;];%49[^;];%19[^\n]\n",
                  &e.protocolo,
                  e.local,
                  e.tipoEmergencia,
                  e.horario) == 4) {

        if (p->topo < MAX - 1)
            p->dados[++p->topo] = e;
    }

    fclose(f);
}

// ===== MAIN =====
int main() {
    Pilha p;
    inicializar(&p);
    carregar(&p);

    int op;
    Emergencia e;

    do {
        printf("\n===== SISTEMA DE EMERGENCIA =====\n");
        printf("1 - Registrar emergencia\n");
        printf("2 - Atender emergencia\n");
        printf("3 - Listar emergencias\n");
        printf("4 - Sair\n");
        printf("Opcao: ");
        scanf("%d", &op);

        switch (op) {

            case 1:
                printf("Protocolo: ");
                scanf("%d", &e.protocolo);

                printf("Local da emergencia: ");
                scanf(" %[^\n]", e.local);

                printf("Tipo de emergencia: ");
                scanf(" %[^\n]", e.tipoEmergencia);

                printf("Horario: ");
                scanf(" %[^\n]", e.horario);

                int r = registrarEmergencia(&p, e);

                if (r == 1)
                    printf("Emergencia registrada!\n");
                else if (r == 0)
                    printf("Limite de emergencias atingido!\n");
                else
                    printf("Protocolo ja existente!\n");

                break;

            case 2:
                if (!atenderEmergencia(&p))
                    printf("Nenhuma emergencia para atender!\n");
                break;

            case 3:
                listarEmergencias(&p);
                break;

            case 4:
                printf("Encerrando sistema...\n");
                break;

            default:
                printf("Opcao invalida!\n");
        }

    } while (op != 4);

    salvar(&p);

    return 0;
}
